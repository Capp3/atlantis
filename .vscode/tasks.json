{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Check (PR gate)",
      "type": "shell",
      "command": "make check",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Ruff Fix",
      "type": "shell",
      "command": "uv run ruff check . --fix",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Type Check",
      "type": "shell",
      "command": "uv run mypy atlantis",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Run Tests",
      "type": "shell",
      "command": "make test",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$python"
      ]
    },
    {
      "label": "Serve Docs",
      "type": "shell",
      "command": "uv run mkdocs serve",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Launch Atlantis (debug)",
      "type": "shell",
      "command": "uv run atlantis --smoke-test",
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "Tech Validation: Mermaid WebEngine",
      "type": "shell",
      "command": "uv run python ${workspaceFolder}/scripts/tech_validation_mermaid_webengine.py",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PYTHONPATH": "${workspaceFolder}"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Launch Atlantis (--log-level DEBUG)",
      "type": "shell",
      "command": "uv run atlantis --log-level DEBUG",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PYTHONPATH": "${workspaceFolder}"
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Coverage",
      "type": "shell",
      "command": "make test-cov",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$python"
      ]
    },
    {
      "label": "Pre-commit (all files)",
      "type": "shell",
      "command": "uv run pre-commit run --all-files",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Build Docs (strict)",
      "type": "shell",
      "command": "uv run mkdocs build --strict",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
